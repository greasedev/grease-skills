                                "favorite_count": 7438,
                                "favorited": false,
                                "full_text": "General Catalyst just co-led a $31.5 million seed round into a blatant rip-off of my company, Kled. \n\n(skip to 40 seconds if you want to skip context)\n\nI would typically not speak on things like this, but this level of blatant copycatting is egregious and completely unacceptable, https://t.co/FOkO70mUSR",
                                "id_str": "2055384102409253056",
                                "is_quote_status": true,
                                "lang": "en",
                                "possibly_sensitive": false,
                                "possibly_sensitive_editable": true,
                                "quote_count": 205,
                                "quoted_status_id_str": "2055320835704152164",
                                "quoted_status_permalink": {
                                  "display": "x.com/yuris/status/2…",
                                  "expanded": "https://twitter.com/yuris/status/2055320835704152164",
