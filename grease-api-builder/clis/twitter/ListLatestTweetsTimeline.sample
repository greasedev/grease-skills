                                        "screen_name": "poolsideai"
                                      }
                                    ]
                                  },
                                  "favorite_count": 50,
                                  "favorited": false,
                                  "full_text": "PFlash now run @poolsideai's Laguna-XS.2 (33B-A3B MoE) on a single RTX 3090.\n\n- 111 tok/s decode @ short ctx\n- 128K TTFT in 15.91s, 5.4x faster prefill vs llama.cpp\n- NIAH passes every (ctx, keep) point up to 131K\n- first MoE target supported by PFlash\n- hand-rolled CUDA, ggml",
                                  "id_str": "2054908897060593720",
                                  "is_quote_status": true,
                                  "lang": "en",
                                  "quote_count": 2,
                                  "quoted_status_id_str": "2054908686112346586",
                                  "quoted_status_permalink": {
                                    "display": "x.com/pupposandro/st…",
