                              "timestamps": [],
                              "urls": [],
                              "user_mentions": []
                            },
                            "favorite_count": 431,
                            "favorited": false,
                            "full_text": "We've gone even farther:\nNemotron 3 Super is 120B and pretrained on 25T tokens in NVFP4.\nNemotron 3 Ultra is ~500B and also pretrained in NVFP4.\n\nAccelerated computing means we rethink every aspect of the AI stack looking for new opportunities to improve efficiency.",
                            "id_str": "2055393135971492034",
                            "is_quote_status": true,
