                                    "is_translatable": false,
                                    "legacy": {
                                      "bookmark_count": 6,
                                      "bookmarked": false,
                                      "conversation_id_str": "2055368456342745098",
                                      "created_at": "Fri May 15 19:23:21 +0000 2026",
                                      "display_text_range": [
                                        0,
                                        280
                                      ],
                                      "entities": {
                                        "hashtags": [],
                                        "smarttags": [],
                                        "symbols": [],
                                        "timestamps": [],
                                        "urls": [],
                                        "user_mentions": [
                                          {
                                            "id_str": "1896755171646132224",
                                            "indices": [
                                              31,
                                              47
                                            ],
                                            "name": "Cogent Security",
                                            "screen_name": "cogent_security"
                                          }
                                        ]
                                      },
                                      "favorite_count": 29,
                                      "favorited": false,
                                      "full_text": "This quote from our friends at @cogent_security says a lot:\n\n“At Cogent, our background agents can produce a huge volume of traces all at once. We need live observability into those systems, and SmithDB has been able to deliver that experience: seeing traces in seconds instead of",
                                      "id_str": "2055368456342745098",
                                      "is_quote_status": true,
                                      "lang": "en",
                                      "quote_count": 1,
                                      "quoted_status_id_str": "2054661816249360553",
                                      "quoted_status_permalink": {
                                        "display": "x.com/ankush_gola11/…",
                                        "expanded": "https://twitter.com/ankush_gola11/status/2054661816249360553",
                                        "url": "https://t.co/0kkMuuKX3p"
                                      },
                                      "reply_count": 0,
                                      "retweet_count": 7,
                                      "retweeted": false,
                                      "user_id_str": "313696214"
                                    },
                                    "note_tweet": {
                                      "is_expandable": true,
                                      "note_tweet_results": {
                                        "result": {
                                          "entity_set": {
                                            "hashtags": [],
                                            "smarttags": [],
                                            "symbols": [],
                                            "urls": [],
                                            "user_mentions": [
                                              {
                                                "id_str": "1896755171646132224",
                                                "indices": [
                                                  31,
                                                  47
                                                ],
                                                "name": "Cogent Security",
                                                "screen_name": "cogent_security"
                                              }
                                            ]
                                          },
                                          "id": "Tm90ZVR3ZWV0OjIwNTUzNjg0NTYyNTg4Nzk0ODg=",
                                          "text": "This quote from our friends at @cogent_security says a lot:\n\n“At Cogent, our background agents can produce a huge volume of traces all at once. We need live observability into those systems, and SmithDB has been able to deliver that experience: seeing traces in seconds instead of minutes, which is what we experienced when testing other providers.”\n\nWhen building SmithDB, we focused heavily not only on query performance but also ingestion performance.\n\nWe spent a lot of time meticulously optimizing our ingestion path (batching, compressing, indexing, uploading, etc) to achieve sub-second median write latency. \n\nThis is a time it takes for data to be durably stored and become available to queries from the time the data is received.\n\nWaiting tens of second or even minutes for your traces to show up is completely unacceptable."
                                        }
                                      }
                                    },
                                    "quotedRefResult": {
