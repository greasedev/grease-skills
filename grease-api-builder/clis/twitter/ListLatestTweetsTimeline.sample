                          "is_translatable": false,
                          "legacy": {
                            "bookmark_count": 178,
                            "bookmarked": false,
                            "conversation_id_str": "2055393135971492034",
                            "created_at": "Fri May 15 21:01:25 +0000 2026",
                            "display_text_range": [
                              0,
                              266
                            ],
                            "entities": {
                              "hashtags": [],
                              "smarttags": [],
