                                            "indices": [
                                              313,
                                              322
                                            ],
                                            "name": "Eiso Kant",
                                            "screen_name": "eisokant"
                                          },
                                          {
                                            "id_str": "774723604412071936",
                                            "indices": [
                                              324,
                                              337
                                            ],
                                            "name": "Eric Alcaide",
                                            "screen_name": "eric_alcaide"
                                          },
                                          {
                                            "id_str": "1656921305084485635",
                                            "indices": [
                                              359,
                                              370
                                            ],
                                            "name": "poolside",
                                            "screen_name": "poolsideai"
                                          }
                                        ]
                                      },
                                      "id": "Tm90ZVR3ZWV0OjIwNTQ5MDg4OTY5NTE2MzE4NzQ=",
                                      "richtext": {
                                        "richtext_tags": []
                                      },
                                      "text": "PFlash now run @poolsideai's Laguna-XS.2 (33B-A3B MoE) on a single RTX 3090.\n\n- 111 tok/s decode @ short ctx\n- 128K TTFT in 15.91s, 5.4x faster prefill vs llama.cpp\n- NIAH passes every (ctx, keep) point up to 131K\n- first MoE target supported by PFlash\n- hand-rolled CUDA, ggml only, no libllama\n\ngreat collab w/ @eisokant, @eric_alcaide, and the rest of the @poolsideai team. looking forward to working more on their great coding models.\n\nrepo + GGUF in first comment."
                                    }
                                  }
                                },
