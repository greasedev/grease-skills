                                    "grok_analysis_button": true,
                                    "grok_translated_post_with_availability": {
                                      "is_available": false
                                    },
                                    "is_translatable": false,
                                    "legacy": {
                                      "bookmark_count": 68,
                                      "bookmarked": false,
                                      "conversation_id_str": "2054661816249360553",
                                      "created_at": "Wed May 13 20:35:25 +0000 2026",
                                      "display_text_range": [
                                        0,
                                        279
                                      ],
                                      "entities": {
                                        "hashtags": [],
                                        "smarttags": [],
                                        "symbols": [],
                                        "timestamps": [],
                                        "urls": [],
                                        "user_mentions": []
                                      },
                                      "favorite_count": 97,
                                      "favorited": false,
                                      "full_text": "We built SmithDB: the database purpose built for agent observability workloads that now powers many parts of LangSmith.\n\nAgent observability presents a challenging data problem. Agent traces can contain tens of thousands of intermediate spans and large, unbounded payloads. These",
                                      "id_str": "2054661816249360553",
                                      "is_quote_status": true,
                                      "lang": "en",
                                      "quote_count": 7,
                                      "quoted_status_id_str": "2054658661776244936",
                                      "quoted_status_permalink": {
                                        "display": "x.com/LangChain/stat…",
                                        "expanded": "https://twitter.com/LangChain/status/2054658661776244936",
                                        "url": "https://t.co/nPuL42OVpK"
                                      },
                                      "reply_count": 7,
                                      "retweet_count": 18,
                                      "retweeted": false,
                                      "user_id_str": "313696214"
                                    },
                                    "note_tweet": {
                                      "is_expandable": true,
                                      "note_tweet_results": {
                                        "result": {
                                          "entity_set": {
                                            "hashtags": [],
                                            "smarttags": [],
                                            "symbols": [],
                                            "urls": [],
                                            "user_mentions": []
                                          },
                                          "id": "Tm90ZVR3ZWV0OjIwNTQ2NjE4MTYxNDg3MTc1Njg=",
                                          "richtext": {
                                            "richtext_tags": []
                                          },
                                          "text": "We built SmithDB: the database purpose built for agent observability workloads that now powers many parts of LangSmith.\n\nAgent observability presents a challenging data problem. Agent traces can contain tens of thousands of intermediate spans and large, unbounded payloads. These characteristics are a direct result of agents running for longer time horizons and LLM context window sizes growing.\n\nTraditional data infrastructure was not built to handle the complexities associated with storing and querying this data. \n\nSmithDB brings LangSmith up to 12x performance improvements across access patterns most important for agent observability. I’ve been working on SmithDB directly with an amazing team over the past few months, and I’m incredibly proud of the results we’re seeing.\n\nI wrote a bit more about the story and engineering challenges behind SmithDB in this blog.\n\nAdditionally, if you’re a systems engineer interested in building the future of agent observability, please reach out!"
                                        }
                                      }
                                    },
                                    "quotedRefResult": {
                                      "result": {
                                        "__typename": "Tweet",
                                        "rest_id": "2054658661776244936"
                                      }
                                    },
                                    "rest_id": "2054661816249360553",
                                    "source": "<a href=\"https://mobile.twitter.com\" rel=\"nofollow\">Twitter Web App</a>",
                                    "unmention_data": {},
